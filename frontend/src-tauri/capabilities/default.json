{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "log:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "core:window:allow-destroy",
    "core:window:allow-close",
    "core:webview:allow-webview-close"
  ]
}
