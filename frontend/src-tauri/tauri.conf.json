{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "guvercin",
  "version": "0.1.0",
  "identifier": "com.guvercin.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "if [ -f package.json ]; then npm run dev; else npm --prefix .. run dev; fi",
    "beforeBuildCommand": "if [ -f package.json ]; then npm run build; else npm --prefix .. run build; fi"
  },
  "app": {
    "windows": [
      {
        "title": "Guvercin",
        "width": 1000,
        "height": 700,
        "minWidth": 850,
        "minHeight": 600,
        "resizable": true,
        "devtools": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "rpm"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}